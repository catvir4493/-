; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="深夜愿望便利店"
run/main_scene="res://scenes/main_menu/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

DataManager="*res://scripts/managers/DataManager.gd"
SaveManager="*res://scripts/managers/SaveManager.gd"
InventorySystem="*res://scripts/systems/InventorySystem.gd"
CustomerSystem="*res://scripts/systems/CustomerSystem.gd"
CustomerProgressSystem="*res://scripts/systems/CustomerProgressSystem.gd"
ScoreSystem="*res://scripts/systems/ScoreSystem.gd"
ComboSystem="*res://scripts/systems/ComboSystem.gd"
NightStatsSystem="*res://scripts/systems/NightStatsSystem.gd"
GameManager="*res://scripts/managers/GameManager.gd"

[dotnet]

project/assembly_name="Midnight Wish Mart"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
